{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "noUncheckedIndexedAccess": true
  },
  "include": ["packages/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", "dist", "packages/snippet-manager/src/renderer/**/*"]
}
