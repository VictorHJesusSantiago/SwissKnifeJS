{
  "name": "swissknife-productivity",
  "displayName": "SwissKnife Productivity",
  "version": "1.0.0",
  "publisher": "swissknife",
  "engines": {"vscode":"^1.101.0"},
  "main": "./dist/extension.js",
  "activationEvents": ["onCommand:swissknife.startFocus","onCommand:swissknife.quickNote"],
  "contributes": {
    "commands": [
      {"command":"swissknife.startFocus","title":"SwissKnife: Iniciar foco"},
      {"command":"swissknife.stopFocus","title":"SwissKnife: Encerrar foco"},
      {"command":"swissknife.quickNote","title":"SwissKnife: Nota rápida"}
    ],
    "configuration": {
      "title": "SwissKnife",
      "properties": {
        "swissknife.focusMinutes":{"type":"number","default":25,"minimum":1,"description":"Duração da sessão de foco"}
      }
    }
  },
  "scripts": {"build":"tsc -p tsconfig.json"}
}
